[Unit]
Description=CamMatrix React Frontend (via npx serve)
After=network.target

[Service]
User=root
# Pastikan jalur sesuai dengan folder frontend
WorkingDirectory=/var/www/CamMatrix/frontend

# Mengeksekusi Nginx versi ringan (npm tools) untuk melayani build React ke Web
ExecStart=/usr/bin/npx serve -s dist -l 5173

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
