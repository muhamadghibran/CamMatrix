# ==============================================================================
# CCTV VMS Platform - Environment Variables
# Salin file ini menjadi .env dan isi nilainya sesuai environment Anda.
# JANGAN commit file .env ke Git!
# ==============================================================================

# --- Keamanan Aplikasi ---
SECRET_KEY=ganti-dengan-random-string-sangat-panjang-dan-rahasia
DEBUG=False

# --- Database PostgreSQL ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cctv_vms

# --- Storage MinIO (S3 Compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=cctv-recordings
MINIO_SECURE=False

# --- Media Server (MediaMTX) ---
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_RTSP_BASE=rtsp://localhost:8554

# --- Konfigurasi AI Engine ---
# "auto" = sistem deteksi otomatis (pakai CUDA jika ada, fallback ke CPU)
# "cuda" = paksa GPU
# "cpu"  = paksa CPU
AI_DEVICE=auto
AI_FRAME_SAMPLE_RATE=5
AI_FACE_CONFIDENCE=0.75
AI_SIMILARITY_THRESHOLD=0.60
